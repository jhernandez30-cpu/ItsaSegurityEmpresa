<article class="project-card h-100">
    <div class="project-image" style="background-image:url('@Item.ImageUrl');"></div>

    <div class="project-body">
        <span class="project-category">@Item.Category</span>
        <h3 class="h4 mt-2">@Item.Title</h3>
        <p class="text-secondary">@Item.Description</p>

        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var tag in Item.Tags)
            {
                <span class="chip">@tag</span>
            }
        </div>

        <a class="btn btn-outline-light rounded-pill px-3"
           href="@Item.Url"
           target="_blank"
           rel="noopener noreferrer">
            Ver detalle
        </a>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public ProjectItem Item { get; set; } = default!;
}
