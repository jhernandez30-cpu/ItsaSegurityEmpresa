<section id="experiencia" class="section-spacing reveal">
    <div class="container">
        <SectionHeader
            Kicker="Trayectoria"
            Title="Evolución constante"
            Copy="Una línea de tiempo clara, ligera y totalmente adaptable a móvil." />

        <div class="timeline">
            @foreach (var item in Data.Experience)
            {
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <span class="timeline-year">@item.Year</span>
                        <h3 class="h5 mt-2">@item.Title</h3>
                        <p class="text-secondary mb-0">@item.Description</p>
                    </div>
                </div>
            }
        </div>

        <div class="mt-5">
            <h3 class="h5 mb-3">Certificaciones y alianzas</h3>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var item in Data.Certifications)
                {
                    <span class="chip">@item</span>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public PortfolioData Data { get; set; } = default!;
}
