@page "/contacto"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Contacto | ITSA Segurity</PageTitle>

<section class="hero contacto-hero">
    <div id="particles-js"></div>

    <div class="hero-content container">
        <span class="section-subtitle">· Contacto ·</span>
        <h1 class="page-title">Contacta con <span class="accent">nosotros</span></h1>
        <p class="page-subtitle">
            Estamos a un mensaje de distancia. Cuéntanos qué quieres construir y te ayudamos a convertirlo en una solución real.
        </p>
    </div>
</section>

<section class="section reveal">
    <div class="container grid-2 contacto-grid">
        <div class="contact-info-large glass-card contact-info-panel">
            <span class="section-subtitle">· Información ·</span>
            <h2>Hablemos sobre tu proyecto</h2>
            <p class="contact-lead">
                Podemos ayudarte con desarrollo web, software a medida, ciberseguridad, marketing digital e integración de IA.
            </p>

            <div class="contact-data-list">
                <div class="contact-data-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div>
                        <strong>Ubicación</strong>
                        <span>Managua, Nicaragua</span>
                    </div>
                </div>

                <div class="contact-data-item">
                    <i class="fas fa-phone-alt"></i>
                    <div>
                        <strong>Teléfono</strong>
                        <a href="tel:+50589871374">+505 8987 1374</a>
                    </div>
                </div>

                <div class="contact-data-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <strong>Correo</strong>
                        <a href="mailto:info@itsasegurity.com">info@itsasegurity.com</a>
                    </div>
                </div>
            </div>

            <div class="contact-side-card">
                <h3>¿Qué puedes esperar?</h3>
                <ul>
                    <li>Respuesta clara y rápida</li>
                    <li>Enfoque orientado a negocio</li>
                    <li>Propuesta moderna y escalable</li>
                    <li>Comunicación profesional</li>
                </ul>
            </div>

            <div class="social-large">
                <a href="https://www.instagram.com/it_segurity" target="_blank" aria-label="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
                <a href="https://www.facebook.com/share/185VZEYC35/" target="_blank" aria-label="Facebook">
                    <i class="fab fa-facebook-f"></i>
                </a>
                <a href="https://www.tiktok.com/@@it._segurity" target="_blank" aria-label="TikTok">
                    <i class="fab fa-tiktok"></i>
                </a>
                <a href="https://wa.me/50589871374" target="_blank" aria-label="WhatsApp">
                    <i class="fab fa-whatsapp"></i>
                </a>
            </div>
        </div>

        <div class="glass-card contact-form-panel">
            <span class="section-subtitle">· Formulario ·</span>
            <h2>Envíanos un mensaje</h2>
            <p class="contact-form-copy">
                Completa el formulario y te responderemos lo antes posible.
            </p>

            <EditForm EditContext="_editContext" OnValidSubmit="SubmitAsync" class="contact-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="name">Nombre completo</label>
                    <InputText id="name" class="form-input" @bind-Value="_model.Name" />
                    <ValidationMessage For="@(() => _model.Name)" />
                </div>

                <div class="form-group">
                    <label for="email">Correo electrónico</label>
                    <InputText id="email" class="form-input" @bind-Value="_model.Email" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="form-group">
                    <label for="subject">Asunto</label>
                    <InputText id="subject" class="form-input" @bind-Value="_model.Subject" />
                    <ValidationMessage For="@(() => _model.Subject)" />
                </div>

                <div class="form-group">
                    <label for="service">Tipo de servicio</label>
                    <InputSelect id="service" class="form-select" @bind-Value="_model.Service">
                        <option value="">Selecciona un servicio</option>
                        <option value="desarrollo-web">Desarrollo Web</option>
                        <option value="software-medida">Software a medida</option>
                        <option value="ciberseguridad">Ciberseguridad</option>
                        <option value="marketing-digital">Marketing Digital</option>
                        <option value="ia-datos">IA & Datos</option>
                        <option value="consultoria">Consultoría</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => _model.Service)" />
                </div>

                <div class="form-group">
                    <label for="message">Mensaje</label>
                    <InputTextArea id="message" class="form-input" rows="6" @bind-Value="_model.Message" />
                    <ValidationMessage For="@(() => _model.Message)" />
                </div>

                <button type="submit" class="btn btn-primary btn-block" disabled="@_sending">
                    @(_sending ? "Enviando..." : "Enviar mensaje")
                </button>

                @if (!string.IsNullOrWhiteSpace(_statusMessage))
                {
                    <div class="form-status" style="display:block">
                        <p>@_statusMessage</p>
                    </div>
                }
            </EditForm>
        </div>
    </div>
</section>

<section class="section reveal" style="padding-top: 0;">
    <div class="container">
        <div class="glass-card cta-final-home">
            <h2>¿Prefieres hablar directamente?</h2>
            <p>
                También puedes escribirnos por WhatsApp o coordinar una llamada para revisar tu idea con más detalle.
            </p>
            <div class="hero-cta" style="justify-content:center;">
                <a href="https://wa.me/50589871374" target="_blank" class="btn btn-primary">
                    Escribir por WhatsApp
                </a>
                <NavLink href="/servicios" class="btn btn-outline">
                    Ver servicios
                </NavLink>
            </div>
        </div>
    </div>
</section>

@code {
    private ContactFormModel _model = new();
    private EditContext _editContext = default!;
    private bool _initialized;
    private bool _sending;
    private string _statusMessage = string.Empty;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            try
            {
                await JS.InvokeVoidAsync("itsaPages.initParticles", "particles-js");
                await JS.InvokeVoidAsync("siteEffects.initReveal");
            }
            catch
            {
                // Las funciones JS se cargarán cuando estén disponibles
            }
        }
    }

    private async Task SubmitAsync()
    {
        _sending = true;
        _statusMessage = string.Empty;

        try
        {
            var payload = new Dictionary<string, string>
            {
                ["name"] = _model.Name,
                ["email"] = _model.Email,
                ["_subject"] = string.IsNullOrWhiteSpace(_model.Subject)
                    ? "Nuevo mensaje desde ITSA Segurity"
                    : _model.Subject,
                ["service"] = _model.Service,
                ["message"] = _model.Message
            };

            using var content = new FormUrlEncodedContent(payload);
            using var request = new HttpRequestMessage(HttpMethod.Post, "https://formspree.io/f/xnjojrwb")
            {
                Content = content
            };

            request.Headers.Accept.ParseAdd("application/json");

            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                _statusMessage = "Mensaje enviado correctamente. Te responderemos pronto.";
                _model = new ContactFormModel();
                _editContext = new EditContext(_model);
            }
            else
            {
                _statusMessage = "No se pudo enviar el mensaje. Intenta nuevamente.";
            }
        }
        catch
        {
            _statusMessage = "Ocurrió un error al enviar el formulario.";
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }

    private sealed class ContactFormModel
    {
        [Required(ErrorMessage = "El nombre es obligatorio.")]
        [StringLength(120)]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio.")]
        [EmailAddress(ErrorMessage = "Correo no válido.")]
        public string Email { get; set; } = string.Empty;

        [StringLength(150)]
        public string Subject { get; set; } = "Nuevo mensaje desde ITSA Segurity";

        [Required(ErrorMessage = "Selecciona un servicio.")]
        public string Service { get; set; } = string.Empty;

        [Required(ErrorMessage = "El mensaje es obligatorio.")]
        [MinLength(10, ErrorMessage = "El mensaje debe tener al menos 10 caracteres.")]
        [StringLength(2000)]
        public string Message { get; set; } = string.Empty;
    }
}
