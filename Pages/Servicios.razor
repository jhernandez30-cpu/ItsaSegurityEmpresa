@page "/servicios"
@inject IJSRuntime JS

<PageTitle>Servicios | ITSA Segurity</PageTitle>

<section class="hero servicios-hero" id="servicios-hero">
    <div id="particles-js-servicios"></div>

    <div class="hero-content container">
        <span class="section-subtitle">· Soluciones digitales ·</span>

        <h1 class="servicios-title">
            Nuestros <span class="accent">servicios</span>
        </h1>

        <p class="servicios-subtitle">
            Construimos productos digitales de alta calidad, integramos IA y potenciamos tu negocio con tecnología avanzada.
        </p>

        <div class="hero-cta">
            <NavLink href="/contacto" class="btn btn-primary">
                Solicitar asesoría
            </NavLink>
            <NavLink href="/tecnologia" class="btn btn-outline">
                Ver stack tecnológico
            </NavLink>
        </div>
    </div>
</section>

<section class="section servicios-grid-section reveal">
    <div class="container">
        <span class="section-subtitle">· Qué hacemos ·</span>
        <h2 class="section-title">
            Servicios pensados para <span class="accent">crecer contigo</span>
        </h2>
        <p class="text-center intro-copy">
            Desde presencia web hasta plataformas a medida, seguridad digital y automatización, diseñamos soluciones con visión estratégica y ejecución sólida.
        </p>

        <div class="servicios-grid servicios-grid-6">
            @foreach (var item in Services)
            {
                <div class="servicio-card servicio-card-lg">
                    <i class="@item.Icon card-icon"></i>
                    <h3>@item.Title</h3>
                    <p class="card-description">@item.Description</p>
                    <NavLink href="/contacto" class="card-link">
                        Explorar servicio <i class="fas fa-arrow-right"></i>
                    </NavLink>
                </div>
            }
        </div>
    </div>
</section>

<section class="section reveal" style="padding-top: 0;">
    <div class="container">
        <div class="glass-card services-highlight">
            <div class="grid-2">
                <div>
                    <span class="section-subtitle">· Enfoque integral ·</span>
                    <h2 class="section-title">
                        Tecnología, estrategia y <span class="accent">ejecución</span>
                    </h2>
                    <p class="section-paragraph">
                        No trabajamos solo sobre requerimientos técnicos. Analizamos el contexto de negocio,
                        la experiencia del usuario, la seguridad del sistema y la escalabilidad futura.
                    </p>
                </div>

                <div class="services-highlight-list">
                    <div class="highlight-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Arquitectura orientada a crecimiento</span>
                    </div>
                    <div class="highlight-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Diseño visual profesional y moderno</span>
                    </div>
                    <div class="highlight-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Seguridad incorporada desde el inicio</span>
                    </div>
                    <div class="highlight-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Automatización y eficiencia operativa</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="metodologia-section section reveal">
    <div class="container">
        <span class="section-subtitle">· Cómo trabajamos ·</span>
        <h2 class="section-title">
            Un proceso claro, ágil y <span class="accent">medible</span>
        </h2>
        <p class="text-center intro-copy">
            Un proceso probado que combina agilidad, transparencia y comunicación constante.
        </p>

        <div class="metodologia-grid metodologia-grid-4">
            @foreach (var step in Steps)
            {
                <div class="metodologia-item">
                    <span class="metodologia-number">@step.Number</span>
                    <h4>@step.Title</h4>
                    <p>@step.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="tecnologias-section section reveal">
    <div class="container">
        <span class="section-subtitle">· Stack ·</span>
        <h2 class="section-title">
            Tecnologías que <span class="accent">utilizamos</span>
        </h2>
        <p class="text-center intro-copy">
            Seleccionamos herramientas modernas según el objetivo del proyecto, no por moda.
        </p>

        <div class="tech-cloud tech-cloud-centered">
            @foreach (var tech in TechStack)
            {
                <span class="tech-item">@tech</span>
            }
        </div>
    </div>
</section>

<section class="section reveal" style="padding-top: 0;">
    <div class="container">
        <div class="stats-grid">
            @foreach (var metric in Metrics)
            {
                <div class="stat-large">
                    <span class="stat-number">@metric.Number</span><span>@metric.Suffix</span>
                    <p>@metric.Label</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="cta-section section reveal">
    <div class="container">
        <div class="glass-card cta-content cta-content-centered">
            <span class="section-subtitle">· Siguiente paso ·</span>
            <h2>¿Listo para transformar tu idea en un producto real?</h2>
            <p>
                Hablemos de tu proyecto. Sin compromiso, solo una conversación para entender cómo podemos ayudarte.
            </p>
            <div class="hero-cta" style="justify-content:center;">
                <NavLink href="/contacto" class="btn btn-primary">
                    Agenda una llamada
                </NavLink>
                <NavLink href="/metodologia" class="btn btn-outline">
                    Ver metodología
                </NavLink>
            </div>
        </div>
    </div>
</section>

@code {
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_initialized)
        {
            _initialized = true;
            await JS.InvokeVoidAsync("itsaPages.initParticles", "particles-js-servicios");
            await JS.InvokeVoidAsync("itsaPages.initGsap");
            await JS.InvokeVoidAsync("siteEffects.initReveal");
        }
    }

    private readonly List<ServiceItem> Services =
    [
        new("Desarrollo Web", "fas fa-laptop-code", "Sitios y aplicaciones con narrativa visual, alto rendimiento y las últimas tecnologías frontend y backend."),
        new("Software a medida", "fas fa-cogs", "Aplicaciones de escritorio, móviles y cloud con arquitecturas escalables y metodologías ágiles."),
        new("Ciberseguridad", "fas fa-shield-halved", "Auditorías, pentesting, protección de datos y monitorización 24/7 para mantener tu negocio seguro."),
        new("Marketing Digital", "fas fa-bullseye", "Estrategias basadas en datos: SEO, SEM, redes sociales y automatización para maximizar conversiones."),
        new("IA & Datos", "fas fa-brain", "Integración de inteligencia artificial, análisis de datos y modelos predictivos para tu negocio."),
        new("Consultoría", "fas fa-chart-pie", "Asesoramiento experto en arquitectura, tecnología y transformación digital para empresas.")
    ];

    private readonly List<StepItem> Steps =
    [
        new("01", "Discovery", "Entendemos tu visión, necesidades y objetivos de negocio."),
        new("02", "Scope", "Planificamos la arquitectura y el roadmap del proyecto."),
        new("03", "Build", "Construimos el producto de forma iterativa con demos semanales."),
        new("04", "Launch", "Desplegamos a producción y aseguramos un lanzamiento exitoso.")
    ];

    private readonly List<string> TechStack =
    [
        "React", "Node.js", "Python", "TypeScript", "Next.js", "Docker",
        "AWS", "MongoDB", "PostgreSQL", "TensorFlow", "Flutter", "GitHub"
    ];

    private readonly List<MetricItem> Metrics =
    [
        new("120", "+", "Proyectos y soluciones entregadas"),
        new("98", "%", "Enfoque orientado a satisfacción"),
        new("24", "/7", "Disponibilidad y continuidad")
    ];

    private sealed record ServiceItem(string Title, string Icon, string Description);
    private sealed record StepItem(string Number, string Title, string Description);
    private sealed record MetricItem(string Number, string Suffix, string Label);
}
