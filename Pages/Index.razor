@page "/"
@inject IJSRuntime JS

<PageTitle>ITSA Segurity | Innovación digital</PageTitle>

<section id="hero" class="hero">
    <div id="three-container" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;"></div>
    <div id="particles-js"></div>

    <div class="hero-content container">
        <h1 class="hero-title">
            Construimos el futuro <br />
            <span class="gradient-text">digital</span> de tu negocio
        </h1>

        <p class="hero-subtitle">
            Desarrollo web, software, ciberseguridad y marketing digital con enfoque storytelling.
        </p>

        <div class="hero-cta">
            <NavLink href="/contacto" class="btn btn-primary">
                Solicitar evaluación gratuita <i class="fas fa-shield-alt"></i>
            </NavLink>
            <NavLink href="/servicios" class="btn btn-outline">Descubre cómo</NavLink>
        </div>
    </div>

    <div class="hero-scroll-indicator">
        <span>Desliza</span>
        <i class="fas fa-chevron-down"></i>
    </div>
</section>

<section id="presentacion" class="section presentacion">
    <div class="container grid-2">
        <div class="presentacion-texto">
            <span class="section-subtitle">· ITSA Segurity ·</span>
            <h2 class="section-title">Donde la tecnología cuenta <span class="accent">historias</span></h2>
            <p class="section-paragraph">
                No solo creamos código: diseñamos experiencias inmersivas que conectan con tu audiencia.
                Fusionamos desarrollo, creatividad y seguridad para llevarte al siguiente nivel.
            </p>

            <div class="stats-mini">
                @foreach (var stat in PresentationStats)
                {
                    <div class="stat-item">
                        <span class="stat-number">@stat.Number</span><span>@stat.Suffix</span>
                        <p>@stat.Label</p>
                    </div>
                }
            </div>
        </div>

        <div class="presentacion-visual">
            <img src="assets/images/presentation.jpg" alt="ITSA tecnología" class="presentation-img" onerror="this.style.display='none'">
            <div class="glass-card" style="margin-top: 1rem;">
                <i class="fas fa-code"></i>
                <i class="fas fa-shield-alt"></i>
                <i class="fas fa-chart-line"></i>
            </div>
        </div>
    </div>
</section>

<section id="servicios" class="section servicios-grid-section" style="background: #0a0c12; padding: 80px 0;">
    <div class="container">
        <span class="section-subtitle">· Nuestra experiencia ·</span>
        <h2 class="section-title">Soluciones integrales <span class="accent">premium</span></h2>

        <div class="servicios-grid" style="margin-top: 3rem;">
            @foreach (var service in Services)
            {
                <div class="servicio-card">
                    <i class="@service.Icon card-icon"></i>
                    <h3>@service.Title</h3>
                    <p class="card-description">@service.Description</p>
                    <NavLink href="/servicios" class="card-link">
                        Explorar servicio <i class="fas fa-arrow-right"></i>
                    </NavLink>
                </div>
            }
        </div>

        <div class="service-cta" style="text-align: center; margin-top: 3rem;">
            <NavLink href="/servicios" class="btn btn-link">
                Ver todos los servicios <i class="fas fa-long-arrow-alt-right"></i>
            </NavLink>
        </div>
    </div>
</section>

<section id="experiencia" class="section experiencia">
    <div class="container">
        <span class="section-subtitle">· Nuestra historia ·</span>
        <h2 class="section-title">Evolución <span class="accent">constante</span></h2>

        <div class="timeline-grid">
            @foreach (var item in Timeline)
            {
                <div class="timeline-item">
                    <div class="timeline-year">@item.Year</div>
                    <div class="timeline-content glass-card">
                        <h4>@item.Title</h4>
                        <p>@item.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="estadisticas" class="section stats">
    <div class="container">
        <div class="stats-grid">
            @foreach (var stat in MainStats)
            {
                <div class="stat-large">
                    <span class="stat-number">@stat.Number</span><span>@stat.Suffix</span>
                    <p>@stat.Label</p>
                </div>
            }
        </div>
    </div>
</section>

<section id="testimonios" class="section testimonios">
    <div class="container">
        <span class="section-subtitle">· Clientes ·</span>
        <h2 class="section-title">Lo que dicen de <span class="accent">nosotros</span></h2>

        <div class="testimonial-carousel" role="region" aria-label="Testimonios de clientes">
            <div class="testimonial-track">
                @foreach (var testimonial in Testimonials)
                {
                    <div class="testimonial-card">
                        <img src="@testimonial.AvatarUrl" alt="@testimonial.Name" class="testimonial-avatar">
                        <p>"@testimonial.Quote"</p>
                        <h5>— @testimonial.Name, @testimonial.Role</h5>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section class="section equipo">
    <div class="container">
        <span class="section-subtitle">· Expertos ·</span>
        <h2 class="section-title">Conoce a nuestro <span class="accent">equipo</span></h2>

        <div class="equipo-grid-horizontal">
            @foreach (var member in Team)
            {
                <div class="miembro-card">
                    <img src="@member.AvatarUrl" alt="@member.Name" class="miembro-avatar">
                    <h4>@member.Name</h4>
                    <p>@member.Role</p>
                    <div class="social-links">
                        @if (!string.IsNullOrWhiteSpace(member.LinkedIn))
                        {
                            <a href="@member.LinkedIn" target="_blank" aria-label="LinkedIn"><i class="fab fa-linkedin"></i></a>
                        }
                        @if (!string.IsNullOrWhiteSpace(member.GitHub))
                        {
                            <a href="@member.GitHub" target="_blank" aria-label="GitHub"><i class="fab fa-github"></i></a>
                        }
                        @if (!string.IsNullOrWhiteSpace(member.Twitter))
                        {
                            <a href="@member.Twitter" target="_blank" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="section certificaciones">
    <div class="container">
        <h2 class="section-title">Certificaciones y <span class="accent">alianzas</span></h2>

        <div class="cert-grid-horizontal">
            @foreach (var cert in Certifications)
            {
                <div class="cert-item">
                    <i class="@cert.Icon"></i>
                    <span>@cert.Name</span>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_initialized)
        {
            _initialized = true;
            await JS.InvokeVoidAsync("itsaPages.initParticles", "particles-js");
            await JS.InvokeVoidAsync("itsaPages.initGsap");
            await JS.InvokeVoidAsync("itsaPages.initThreeBackground", "three-container");
        }
    }

    private readonly List<StatItem> PresentationStats =
    [
        new("6", "+", "Años de experiencia"),
        new("120", "+", "Proyectos exitosos"),
        new("15", "+", "Especialistas")
    ];

    private readonly List<ServiceItem> Services =
    [
        new("Desarrollo Web", "fas fa-laptop-code", "Sitios y aplicaciones con narrativa visual, alto rendimiento y las últimas tecnologías frontend y backend."),
        new("Software a medida", "fas fa-cogs", "Aplicaciones de escritorio, móviles y cloud con arquitecturas escalables y metodologías ágiles."),
        new("Ciberseguridad", "fas fa-shield-halved", "Auditorías, pentesting, protección de datos y monitorización 24/7 para mantener tu negocio seguro."),
        new("Marketing Digital", "fas fa-bullseye", "Estrategias basadas en datos: SEO, SEM, redes sociales y automatización para maximizar conversiones.")
    ];

    private readonly List<TimelineItem> Timeline =
    [
        new("2020", "Nacimiento de ITSA", "Con la visión de fusionar tecnología y narrativa."),
        new("2022", "Expansión en ciberseguridad", "Certificaciones y alianzas estratégicas."),
        new("2026", "+120 proyectos", "Empresas nacionales confían en nosotros.")
    ];

    private readonly List<StatItem> MainStats =
    [
        new("98", "%", "Satisfacción cliente"),
        new("24", "/7", "Soporte continuo"),
        new("15", "+", "Premios innovación")
    ];

    private readonly List<TestimonialItem> Testimonials =
    [
        new("Laura Méndez", "CMO de InnovaCorp", "ITSA transformó nuestra presencia digital. El enfoque storytelling marcó la diferencia.", "https://randomuser.me/api/portraits/women/1.jpg"),
        new("Carlos Rivas", "CTO de FintechPro", "Su equipo de ciberseguridad evitó vulnerabilidades críticas. Altamente recomendados.", "https://randomuser.me/api/portraits/men/1.jpg"),
        new("Ana Soto", "Directora de Operaciones", "El desarrollo de software fue impecable, con entregas ágiles y calidad superior.", "https://randomuser.me/api/portraits/women/2.jpg")
    ];

    private readonly List<TeamMemberItem> Team =
    [
        new("Ing. Juan Pérez", "Director de Seguridad | CEH, CISSP", "https://randomuser.me/api/portraits/men/2.jpg", "#", "#", null),
        new("Dra. María López", "Especialista en Pentesting | OSCP", "https://randomuser.me/api/portraits/women/3.jpg", "#", null, "#"),
        new("Carlos Rivas", "Arquitecto Cloud | AWS Certified", "https://randomuser.me/api/portraits/men/3.jpg", "#", "#", null)
    ];

    private readonly List<CertificationItem> Certifications =
    [
        new("ISO 27001", "fas fa-certificate"),
        new("CEH (Certified Ethical Hacker)", "fas fa-shield-alt"),
        new("AWS Partner", "fab fa-aws"),
        new("Microsoft Partner", "fab fa-microsoft"),
        new("PCI DSS", "fas fa-lock")
    ];

    private sealed record StatItem(string Number, string Suffix, string Label);
    private sealed record ServiceItem(string Title, string Icon, string Description);
    private sealed record TimelineItem(string Year, string Title, string Description);
    private sealed record TestimonialItem(string Name, string Role, string Quote, string AvatarUrl);
    private sealed record TeamMemberItem(string Name, string Role, string AvatarUrl, string? LinkedIn, string? GitHub, string? Twitter);
    private sealed record CertificationItem(string Name, string Icon);
}
