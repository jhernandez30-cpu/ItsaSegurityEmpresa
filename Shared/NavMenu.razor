@* Shared/NavMenu.razor *@
<header class="header">
    <div class="container">
        <nav class="navbar">
            <NavLink href="/" class="logo">
                ITSA <span>Segurity</span>
            </NavLink>

            <button class="hamburger" @onclick="ToggleMenu" aria-label="Menú">
                <i class="fas fa-bars"></i>
            </button>

            <ul class="nav-menu @(_menuOpen ? "open" : "")">
                <li>
                    <NavLink href="/" class="nav-link" Match="NavLinkMatch.All" @onclick="CloseMenu">
                        Inicio
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/servicios" class="nav-link" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                        Servicios
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/tecnologia" class="nav-link" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                        Tecnología
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/contacto" class="nav-link" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                        Contacto
                    </NavLink>
                </li>
            </ul>
        </nav>
    </div>
</header>

@code {
    private bool _menuOpen = false;

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void CloseMenu()
    {
        _menuOpen = false;
    }
}
